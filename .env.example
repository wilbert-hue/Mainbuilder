# ── Dashboard Builder — environment variables ───────────────────────────────
# Copy to .env.local for local dev, or set these in your host's dashboard.

# ── Required for share links ────────────────────────────────────────────────
# MongoDB Atlas connection string. Free tier (M0) is fine for low volume.
# Atlas → Network Access must allow your host (0.0.0.0/0 for serverless/PaaS).
MONGODB_URI=mongodb+srv://user:pass@cluster.mongodb.net/DBbuilder

# Public base URL used to build shareable links (no trailing slash).
# Local: http://localhost:3002   Prod: https://your-app.example.com
NEXT_PUBLIC_APP_URL=http://localhost:3002

# ── Required for auth (login + sessions) ────────────────────────────────────
# Any long random string (e.g. `node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"`).
# Rotating it invalidates all sessions (logs everyone out). Keep secret.
AUTH_SECRET=change-me-to-a-long-random-string

# ── Optional Mongo overrides (defaults shown) ───────────────────────────────
# MONGODB_DB_NAME=DBbuilder
# MONGODB_COLLECTION=Builder

# ── Optional: object storage for LARGE dashboards (S3-compatible) ───────────
# Without these, large dashboards are gzip'd inline into Mongo and capped at
# ~15 MB (~3,500 rows). Setting them offloads big blobs to object storage so
# Mongo only holds metadata + a key — lifting the cap and freeing Atlas space.
#
# Recommended FREE option: Cloudflare R2 (10 GB, 1M writes/mo, no egress fees).
#   1. Create an R2 bucket.
#   2. Create an R2 API token (Object Read & Write) → gives key id + secret.
#   3. Endpoint is https://<ACCOUNT_ID>.r2.cloudflarestorage.com
#
# BLOB_BUCKET=dashboard-blobs
# BLOB_ACCESS_KEY_ID=...
# BLOB_SECRET_ACCESS_KEY=...
# BLOB_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com   # omit for real AWS S3
# BLOB_REGION=auto            # use a real region (e.g. us-east-1) for AWS S3
# BLOB_KEY_PREFIX=dashboards/
